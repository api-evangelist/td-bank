  "info": {
    "_postman_id": "e160931f-979a-4dd3-8817-906d71ef448c",
    "name": "TD Bank Token API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "OAuth 2.0 Token API with Pushed Authorization Request (PAR). Issues access tokens for the FDX Data APIs and the Consent API. The flow: POST /par returns a request_uri; build the consent URL with it and send the user to authorize; exchange the resulting authorization code for an access token via POST /token.\n\nContact Support:\n Name: TD Open Banking Developer Support",
      "type": "text/plain"
    }
  }
