{
  "opencollection": "1.0.0",
  "info": {
    "name": "TD Bank Notifications API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Notifications",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Notifications",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbanking.amcb.developer.td.com/notifications/v1/notifications",
            "params": [
              {
                "name": "category",
                "value": "",
                "type": "query"
              },
              {
                "name": "since",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List Notifications"
        },
        {
          "info": {
            "name": "Get Notification",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbanking.amcb.developer.td.com/notifications/v1/notifications/:notificationId",
            "params": [
              {
                "name": "notificationId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Notification"
        }
      ]
    }
  ],
  "bundled": true
}