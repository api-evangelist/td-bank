{
  "opencollection": "1.0.0",
  "info": {
    "name": "TD Bank Rewards API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://api.openbanking.amcb.developer.td.com/oauth/v1/authorize",
      "accessTokenUrl": "https://api.openbanking.amcb.developer.td.com/oauth/v1/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Rewards",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Rewards Programs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbanking.amcb.developer.td.com/fdx/v6/rewards-programs"
          },
          "docs": "List Rewards Programs"
        },
        {
          "info": {
            "name": "Get Rewards Program",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbanking.amcb.developer.td.com/fdx/v6/rewards-programs/:programId",
            "params": [
              {
                "name": "programId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Rewards Program"
        }
      ]
    }
  ],
  "bundled": true
}